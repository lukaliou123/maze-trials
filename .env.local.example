# Copy this file to .env.local and fill in your DeepSeek API key.
# .env.local is gitignored. Vite will load it automatically in dev mode.
# Used by vite.config.ts to proxy /api/llm to https://api.deepseek.com/v1/chat/completions

DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
